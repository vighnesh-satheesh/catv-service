{
    "apps": [{
        "name": "portal-api",
        "script": "/usr/local/bin/uwsgi",
        "args": "--ini /app/deploy/conf/uwsgi.ini --enable-threads",
        "instances": 1,
        "exec_interpreter": "none",
        "exec_mode": "fork_mode",
        "out_file": "/dev/null",
        "error_file": "/dev/null",
        "max_restarts": 10,
        "restart_delay": 1000
    }, {
        "name": "portal-api-celery",
        "script": "/app/manage.py",
        "args": "celery worker --concurrency=2 --loglevel=INFO",
        "instances": 1,
        "exec_interpreter": "python",
        "exec_mode": "fork_mode",
        "out_file": "/dev/null",
        "error_file": "/dev/null",
        "max_restarts": 10,
        "restart_delay": 1000
    }, {
        "name": "redis-server",
        "script": "/usr/bin/redis-server",
        "instance": 1,
        "exec_interpreter": "none",
        "exec_mode": "fork_mode",
        "out_file": "/dev/null",
        "error_file": "/dev/null",
        "max_restarts": 10,
        "restart_delay": 1000
    }]
}
