{
    "apps": [{
        "name": "portal-consumer",
        "script": "/app/manage.py",
        "args": "consume",
        "instances": 1,
        "exec_interpreter": "python",
        "exec_mode": "fork_mode",
        "out_file": "/dev/null",
        "error_file": "/dev/null",
        "max_restarts": 10,
        "restart_delay": 1000
    }, {
        "name": "redis-server",
        "script": "/usr/bin/redis-server",
        "instance": 1,
        "exec_interpreter": "none",
        "exec_mode": "fork_mode",
        "out_file": "/dev/null",
        "error_file": "/dev/null",
        "max_restarts": 10,
        "restart_delay": 1000
    }]
}
