html
  head
    link(rel='stylesheet' href='https://maxcdn.bootstrapcdn.com/font-awesome/4.4.0/css/font-awesome.min.css')
    script(src='https://kit.fontawesome.com/0a20974b6b.js' crossorigin='anonymous')
  body
    .cara-pg-1
        .heading
            | Crypto Analysis Risk Assessment
        .address {{address}}
        .verdict {{verdict}}
        .report-details
            | Report Details
        .border
        .det-row
            .det-name
                | Address
            .det-value {{address}}
        .det-row
            .det-name
                | Report ID
            .det-value {{id}}
        .det-row
            .det-name
                | Type
            .det-value {{type}}
        .det-row
            .det-name
                | Last Transaction Timestamp
            .det-value {{last_tx_ts}}
        .det-row
            .det-name
                | CARA Search Time
            .det-value {{cara_search}}
        .det-row
            .det-name
                | Report Generated Time
            .det-value {{cara_rep}}
        .det-row
            .det-name
                | Suspicious TX Count
            .det-value {{sus_tx_count}}
        .det-row
            .det-name
                | Suspicious TX Amount
            .det-value {{sus_tx_amt}}
        .det-row
            .det-name
                | Verdict
            .det-value {{verdict}}
        .det-row
            .det-name
                | Summary
            .det-value {{summary}}
        .report-details
            | Machine Learning Transaction Analysis Results
        .border
        .det-row
            .det-name
                | Result
            .det-value {{verdict}}
        .det-row
            .det-name
                | Score
            .det-value {{score}}
        .det-row
            .det-name
                | Summary
            .det-value {{cara_summary}}
        .cara-info
            | Low Risk:0-15    Medium Risk:16-30    High Risk:31-50    Extremely High Risk:51-100
        .report-details
            | Static Analysis Results (TRDB)
        .det-row
            .det-name
                | Result
            .det-value {{trdb_result}}
        .det-row
            .det-name
                | Summary
            .det-value {{trdb_summary}}
        .footer
            .logo
                img(src='static/templates/cara/ic_logo_refresh.png')
